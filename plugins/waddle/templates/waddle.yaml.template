project:
  name: "{{PROJECT_NAME}}"
  description: "{{PROJECT_DESCRIPTION}}"

specialists:
  # Uncomment and set to delegate implementation to domain-specific agents:
  # bash: shellcraft:bash-developer
  # java: javacraft:java-developer

models:
  worker: sonnet  # default for all workers (accepts: sonnet, opus, haiku, or any model ID)
  # Per-role overrides (optional):
  # planner: opus
  # implementer: sonnet
  # reviewer: haiku
  # fixer: sonnet

stewardship:
  # Documents that define "good" for this project.
  # Paths are relative to project root. Created during bootstrap.
  vision: VISION.md
  decisions: DECISIONS.md
  architecture: ARCHITECTURE.md  # created during bootstrap (analyzed for existing codebases, empty for new)

  # Automated audit configuration.
  # frequency: commits between checks (0 = on-demand only)
  # mode: nudge (remind user) or auto (run automatically)
  audits:
    consistency:
      frequency: 8
      mode: nudge
    security:
      frequency: 15
      mode: auto
    architecture:
      frequency: 20
      mode: nudge
    vision:
      frequency: 0
    dx:
      frequency: 0
    debt:
      frequency: 0
