# Generated by shellcraft v1.1 (2026-03-13)
#
# Shellcheck configuration - strict by default
#
# This configuration aligns with bash-style-guide conventions. Only disables
# warnings that conflict with established patterns documented in the skills.
#
# Philosophy: Enable everything by default, only disable with clear rationale
# and cross-references to bash-style-guide sections.
#
# Add project-specific disables below with rationale comments.

# Target shell (prevents POSIX warnings)
# Aligns with bash-style-guide §1: Bash 5.1+ only, not POSIX sh
shell=bash

# SC1090: Can't follow non-constant source
# Rationale: Lazy-loading pattern (bash-patterns §1) uses variables in source paths.
# The guard pattern makes runtime sourcing safe even though shellcheck cannot
# analyze these files statically.
# Example: source "${MYAPP_ROOT}/lib/${module}.sh"
disable=SC1090

# SC1091: Not following: file was not specified as input
# Rationale: Library files may not exist in shellcheck's search path during
# standalone analysis. Guard pattern (bash-style-guide §2) ensures files are
# checked for existence at runtime before sourcing.
# Example: [[ -f "$lib_file" ]] && source "$lib_file"
disable=SC1091

# Enable optional checks for better safety
enable=check-extra-masked-returns
enable=quote-safe-variables
