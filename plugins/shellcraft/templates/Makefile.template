.PHONY: check lint test format format-check install help

check: lint test ## Run all quality checks (default)

lint: ## Run shellcheck on source files
	@echo "Running shellcheck..."
	@shellcheck $(SRC_FILES)
	@echo "✓ Shellcheck passed"

test: ## Run bats test suite
	@echo "Running tests..."
	@$(BATS) $(TEST_DIR)

format: ## Format source files with shfmt
	@echo "Formatting source files..."
	@shfmt -i 0 -w $(SRC_FILES)
	@echo "✓ Formatted $(words $(SRC_FILES)) files"

format-check: ## Check formatting without modifying
	@echo "Checking formatting..."
	@shfmt -i 0 -d $(SRC_FILES)

install: ## Install script to ~/bin (symlink)
	@echo "Installing $(BIN_NAME) to ~/bin/$(INSTALL_NAME)..."
	@mkdir -p ~/bin
	@chmod +x $(BIN_DIR)/$(BIN_NAME)
	@ln -sf "$(CURDIR)/$(BIN_DIR)/$(BIN_NAME)" ~/bin/$(INSTALL_NAME)
	@echo "✓ Installed. Ensure ~/bin is in your PATH."

help: ## Show available targets
	@echo "Available targets:"
	@echo ""
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  %-15s %s\n", $$1, $$2}'
