# Test configuration
TEST_DIR := test
BATS := $(TEST_DIR)/lib/bats-core/bin/bats

# Auto-detect source files
SRC_FILES := $(shell find $(SRC_DIR) -name '*.sh' -o -name '*.bash' 2>/dev/null)

